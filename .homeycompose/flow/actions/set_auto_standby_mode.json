{
  "id": "set_auto_standby_mode",
  "title": {
    "en": "Set auto standby mode"
  },
  "titleFormatted": {
    "en": "Set auto standby mode to [[mode]]"
  },
  "hint": {
    "en": "Sets whether the SolarVault 3 uses sleep standby when idle"
  },
  "args": [
    {
      "type": "device",
      "name": "device",
      "filter": "driver_id=solarvault&class=battery"
    },
    {
      "type": "dropdown",
      "name": "mode",
      "values": [
        {
          "id": "1",
          "label": {
            "en": "Sleep"
          }
        },
        {
          "id": "2",
          "label": {
            "en": "Awake"
          }
        }
      ]
    }
  ]
}
